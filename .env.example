# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.

# Supabase project URL — Settings → Data API, or derive from the project ref:
# https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable key — safe to expose in the browser.
# Settings → API Keys → Publishable (starts with sb_publishable_)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# Supabase secret key — SECRET. Server-side only, for admin writes + imports.
# Bypasses Row Level Security. Never expose this to the browser.
# Settings → API Keys → Secret (starts with sb_secret_)
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxx

# Password for the /admin page. Pick something long and random.
ADMIN_PASSWORD=change-me-to-a-long-random-string

# Tradier brokerage API — server-side only, never expose to the browser.
# Get tokens at: tradier.com/user/api
# Production (real account)
TRADIER_API_KEY=your-production-api-key
TRADIER_ACCOUNT_ID=your-production-account-number

# Sandbox (test environment — safe to hit freely)
TRADIER_SANDBOX_KEY=your-sandbox-api-key
TRADIER_SANDBOX_ACCOUNT=your-sandbox-account-number
